DASHSCOPE_API_KEY=your_dashscope_key
ALI_EMBEDDING_MODEL=text-embedding-v4
ALI_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
ALI_OCR_MODEL=qwen-vl-ocr-latest
ALI_OCR_FALLBACK_MODELS=qwen-vl-ocr,qwen-vl-plus
ALI_VISION_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

CHAT_PROVIDER=nvidia
NVIDIA_API_KEY=your_nvidia_key
NVIDIA_MODEL=z-ai/glm5
NVIDIA_CHAT_URL=https://integrate.api.nvidia.com/v1/chat/completions

MINIMAX_API_KEY=your_minimax_key
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_CHAT_URL=https://api.minimax.chat/v1/text/chatcompletion_v2
